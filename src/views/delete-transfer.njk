{% extends '_layout.njk' %}

{% block content %}
  <div class="col-md-6">
    {% if error %}
      <div class="alert alert-danger">
        {{ error }}
      </div>
    {% endif %}
    <h2>Delete transfer</h2>
    <p>Are you sure you wish to delete transfer of {{ transfer.playerIn.firstName }} {{ transfer.playerIn.lastName }} to {{ transfer.manager.name }}?</p>
    <form method="POST" action="/transfer/delete">
      <input type="hidden" name="crumb" value="{{crumb}}"/>
      <input type="hidden" id="transferId" name="transferId" value="{{ transfer.transferId }}">
      <button type="submit" class="btn btn-primary">Confirm</button>
      <a href="/transfers">Cancel</a>
    </form>
  </div>
{% endblock %}
