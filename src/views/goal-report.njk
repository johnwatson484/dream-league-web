{% extends '_layout.njk' %}

{% block content %}
<h2>Report a missed goal</h2>

{% if success %}
<div class="alert alert-success">
  Your goal report has been submitted and is awaiting admin review.
</div>
{% endif %}

{% if error %}
<div class="alert alert-danger">
  {{ error }}
</div>
{% endif %}

<form method="POST" action="/goal-report">
  <input type="hidden" name="crumb" value="{{ crumb }}"/>

  <div class="form-group">
    <label for="managerId">Manager</label>
    <select class="form-control" id="managerId" name="managerId" required>
      <option value="">Select a manager</option>
      {% for manager in formData.managers %}
        <option value="{{ manager.managerId }}">{{ manager.name }}</option>
      {% endfor %}
    </select>
  </div>

  <div class="form-group">
    <label for="playerId">Player</label>
    <select class="form-control" id="playerId" name="playerId" required>
      <option value="">Select a manager first</option>
    </select>
  </div>

  <div class="form-group">
    <label for="gameweekId">Gameweek</label>
    <select class="form-control" id="gameweekId" name="gameweekId" required>
      <option value="">Select a gameweek</option>
      {% for gw in formData.gameweeks %}
        <option value="{{ gw.gameweekId }}" data-cup-week="{{ gw.isCupWeek }}">Week {{ gw.gameweekId }} ({{ gw.shortDate }})</option>
      {% endfor %}
    </select>
  </div>

  <div class="form-group">
    <label for="goals">Goals</label>
    <input type="number" class="form-control" id="goals" name="goals" min="0" max="10" value="1" required>
  </div>

  <div class="form-group" id="cupGoalsGroup" style="display: none;">
    <label for="goalsCup">Cup goals</label>
    <input type="number" class="form-control" id="goalsCup" name="goalsCup" min="0" max="10" value="0">
  </div>

  <div class="form-group">
    <label for="reason">Reason (optional)</label>
    <input type="text" class="form-control" id="reason" name="reason" maxlength="500" placeholder="e.g. Goal scored Tuesday, missed from results">
  </div>

  <button type="submit" class="btn btn-primary">Submit</button>
</form>

<script id="manager-players-data" type="application/json">
  {
    {% for manager in formData.managers %}
      "{{ manager.managerId }}": [
        {% for player in manager.players %}
          { "playerId": {{ player.playerId }}, "name": "{{ player.firstName }} {{ player.lastName }} ({{ player.team.name }})" }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]{% if not loop.last %},{% endif %}
    {% endfor %}
  }
</script>
<script src="{{ asset('javascripts/goal-report.js') }}"></script>
{% endblock %}
