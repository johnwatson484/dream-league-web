{% extends '_layout.njk' %}

{% block content %}
<h2>Groups</h2>

{% if auth.isAdmin %}
<div class="mb-3">
  <a href="/group/create" class="btn btn-sm btn-outline-primary">Create group</a>
  {% if groups.length %}
  <a href="/fixtures/generate" class="btn btn-sm btn-outline-success ml-2">Generate fixtures</a>
  {% endif %}
</div>
{% endif %}

{% if groups.length %}
<div class="row">
  {% for group in groups %}
  <div class="col-md-6" style="padding-bottom: 20px;">
    <div class="card border-dark">
      <div class="card-header bg-dark text-light d-flex justify-content-between align-items-center">
        <span>{{ group.cup.name }} - {{ group.name }}</span>
        {% if auth.isAdmin %}
        <span>
          <a href="/group/edit?groupId={{ group.groupId }}" class="text-light mr-2"><i class="fa-solid fa-pen-to-square fa-sm"></i></a>
          <a href="/group/delete?groupId={{ group.groupId }}" class="text-light"><i class="fa-solid fa-trash fa-sm"></i></a>
        </span>
        {% endif %}
      </div>
      <div class="card-body p-2">
        <table class="table table-hover table-sm small mb-0">
          <tr>
            <th>Manager</th>
          </tr>
          {% for manager in group.managers %}
          <tr>
            <td><a href="/manager?managerId={{ manager.managerId }}">{{ manager.name }}</a></td>
          </tr>
          {% endfor %}
        </table>
        <div class="mt-2 small text-muted">
          {{ group.groupLegs }} leg{% if group.groupLegs > 1 %}s{% endif %} &middot; Top {{ group.teamsAdvancing }} advance
        </div>
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="alert alert-info">
  No groups created.
</div>
{% endif %}
{% endblock %}
