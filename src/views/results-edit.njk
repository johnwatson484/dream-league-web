{% extends '_layout.njk' %}

{% block content %}
  <h2>Results sheet</h2>

  {%if resultsInput.keepers.length %}
    <form id="frm-results" method="POST" action="/results/edit" data-cup-weeks="{{ resultsInput.cupWeeks | dump | safe }}">
      <input type="hidden" name="crumb" value="{{crumb}}"/>

      <div class="row">
        <div class="col-md-5">
          <div class="form-group">
            <select class="form-control" id="gameweekId" name="gameweekId">
            {% for gameweek in resultsInput.gameweeks %}
              <option value="{{ gameweek.gameweekId }}" data-start-date="{{ gameweek.startDate }}" {% if gameweek.isActive %}selected{% endif %}>Gameweek {{ gameweek.gameweekId }} - {{ gameweek.shortDate }}</option>
            {% endfor %}
            </select>
          </div>
        </div>

        <div class="col-md-3">
          <div class="form-group">
            <button type="button" id="results-assistant" class="btn btn-outline-primary"
              data-toggle="tooltip" data-placement="bottom"
              title="Applies goal and concede data gathered from the live videprinter for this gameweek. Review and adjust before submitting.">
              <i class="fa-solid fa-wand-magic-sparkles"></i> Results Assistant
            </button>
          </div>
        </div>

        <div class="col-md-4">
          <div class="form-group float-md-right">
            <button type="submit" class="btn btn-success">Submit results</button>
          </div>
        </div>
      </div>

      <div id="assistant-alerts" class="mb-3"></div>

      <h4>Goalkeepers</h4>

      <table class="table table-sm table-hover small">
        <tr>
          <th>
            <span class="no-mobile">Division</span>
            <span class="mobile-only">Div</span>
          </th>
          <th>Team</th>
          <th>
            <span class="no-mobile">Substitute</span>
            <span class="mobile-only">Sub</span>
          </th>
          <th>Manager</th>
          <th width="110px;">Conceded</th>
          <th width="110px;" class="manager-cup-input-container">Cup</th>
        </tr>
        {% for keeper in resultsInput.keepers %}
          <tr>
            <td>
              <span class="no-mobile">{{ keeper.division }}</span>
              <span class="mobile-only">{{ keeper.divisionShortName }}</span>
            </td>
            <td>{{ keeper.team }}</td>
            <td>{{ keeper.substitute }}</td>
            <td>{{ keeper.manager }}</td>
            <td width="110px;">
              <div class="input-group">
                <div class="input-group-prepend">
                  <button type="button" class="btn btn-danger btn-number btn-sm minus" data-type="minus" data-field="conceded">
                    <i class="fa-solid fa-minus fa-2xs"></i>
                  </button>
                </div>
                <input type="hidden" name="conceded[{{ loop.index0 }}][teamId]" value="{{ keeper.teamId }}"/>
                <input type="text" class="js-select-on-click form-control input-xs result-input" name="conceded[{{ loop.index0 }}][conceded]" style="text-align:center; min-width:20px;" value="0"/>
                <div class="input-group-append">
                  <button type="button" class="btn btn-success btn-number btn-sm plus" data-type="plus" data-field="conceded">
                    <i class="fa-solid fa-plus fa-2xs"></i>
                  </button>
                </div>
              </div>
            </td>
            <td width="110px;" class="manager-cup-input-container">
              <div class="input-group manager-cup-input manager-cup-{{ keeper.managerId }}">
                <div class="input-group-prepend">
                  <button type="button" class="btn btn-danger btn-number btn-sm minus" data-type="minus" data-field="conceded">
                    <i class="fa-solid fa-minus fa-2xs"></i>
                  </button>
                </div>
                <input type="hidden" name="concededCup[{{ loop.index0 }}][teamId]" value="{{ keeper.teamId }}"/>
                <input type="text" class="js-select-on-click form-control input-xs result-input" name="concededCup[{{ loop.index0 }}][conceded]" style="text-align:center; min-width:20px;" value="0"/>
                <div class="input-group-append">
                  <button type="button" class="btn btn-success btn-number btn-sm plus" data-type="plus" data-field="conceded">
                    <i class="fa-solid fa-plus fa-2xs"></i>
                  </button>
                </div>
              </div>
            </td>
          </tr>
        {% endfor %}
        </table>

        <h4>Players</h4>

        <table class="table table-sm table-hover small">
        <tr>
          <th>
            <span class="no-mobile">Division</span>
            <span class="mobile-only">Div</span>
          </th>
          <th>Team</th>
          <th>Player</th>
          <th>Manager</th>
          <th width="110px;">Goals</th>
          <th width="110px;" class="manager-cup-input-container">Cup</th>
        </tr>
        {% for player in resultsInput.players %}
          <tr>
            <td>
              <span class="no-mobile">{{ player.division }}</span>
              <span class="mobile-only">{{ player.divisionShortName }}</span>
            </td>
            <td>{{ player.team }}</td>
            <td>{{ player.lastName }}, {{ player.firstName }}</td>
            <td>{{ player.manager }}</td>
            <td width="110px;">
              <div class="input-group">
                <div class="input-group-prepend">
                  <button type="button" class="btn btn-danger btn-number btn-sm minus" data-type="minus" data-field="goals">
                    <i class="fa-solid fa-minus fa-2xs"></i>
                  </button>
                </div>
                <input type="hidden" name="goals[{{ loop.index0 }}][playerId]" value="{{ player.playerId }}"/>
                <input type="text" class="js-select-on-click form-control input-xs result-input" name="goals[{{ loop.index0 }}][goals]" style="text-align:center; min-width:20px;" value="0" />
                <div class="input-group-append">
                  <button type="button" class="btn btn-success btn-number btn-sm plus" data-type="plus" data-field="goals">
                    <i class="fa-solid fa-plus fa-2xs"></i>
                  </button>
                </div>
              </div>
            </td>
            <td width="110px;" class="manager-cup-input-container">
              <div class="input-group manager-cup-input manager-cup-{{ player.managerId }}">
                <div class="input-group-prepend">
                  <button type="button" class="btn btn-danger btn-number btn-sm minus" data-type="minus" data-field="goals">
                    <i class="fa-solid fa-minus fa-2xs"></i>
                  </button>
                </div>
                <input type="hidden" name="goalsCup[{{ loop.index0 }}][playerId]" value="{{ player.playerId }}"/>
                <input type="text" class="js-select-on-click form-control input-xs result-input" name="goalsCup[{{ loop.index0 }}][goals]" style="text-align:center; min-width:20px;" value="0" />
                <div class="input-group-append">
                  <button type="button" class="btn btn-success btn-number btn-sm plus" data-type="plus" data-field="goals">
                    <i class="fa-solid fa-plus fa-2xs"></i>
                  </button>
                </div>
              </div>
            </td>
          </tr>
        {% endfor %}
      </table>
    </form>
  {% else %}
    <div class="alert alert-info">
      No players available.
    </div>
  {% endif %}
{% endblock %}

{% block bodyEnd %}
  <script src="{{ asset('javascripts/results-edit.js') }}"></script>
{% endblock %}
