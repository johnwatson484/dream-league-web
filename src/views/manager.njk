{% extends '_layout.njk' %}

{% block content %}
  <h2 id="manager-heading">{{ manager.name }}</h2>

  <div class="row" style="padding-bottom: 20px;">
    <div class="col-lg-6">
      <div class="card border-dark">
        <div class="card-header bg-dark text-light">
        Team
      </div>
        <div class="card-body small">
          <div style="padding-bottom:20px;">
            <h6>Goalkeepers</h6>
            <div class="row no-mobile">
              <div class="col-2 font-weight-bold no-mobile">Position</div>
              <div class="col-4 font-weight-bold no-mobile">Team</div>
              <div class="col-4 font-weight-bold no-mobile">Conceded</div>
            </div>
            {% for keeper in team.keepers %}
              <div class="row">
                <div class="col-2">GK {% if keeper.substitute %}(s){% endif %}
                </div>
                <div class="col-4"><a href="/league/player/detail?playerId={{ keeper.playerId }}">{{ keeper.name}}</a></div>
                <div class="col-4">{{ keeper.conceded}} ({{ keeper.cupConceded }})</div>
              </div>
            {% endfor %}
          </div>
          <h6>Players</h6>
          <div class="row no-mobile">
            <div class="col-2 font-weight-bold no-mobile">Position</div>
            <div class="col-4 font-weight-bold no-mobile">Name</div>
            <div class="col-4 font-weight-bold no-mobile">Team</div>
            <div class="col-2 font-weight-bold no-mobile">Goals</div>
          </div>
          {% for player in team.players %}
            <div class="row">
              <div class="col-2">{{ player.position[0] }}
                {% if player.substitute %}(s){% endif %}
              </div>
              <div class="col-4"><a href="/league/player/detail?playerId={{ player.playerId }}">{{ player.fullName}}</a></div>
              <div class="col-4"><a href="/league/team/detail?teamId={{ player.teamId }}">{{ player.team}}</a></div>
              <div class="col-2">{{ player.goals}} ({{ player.cupGoals }})</div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-dark">
        <div class="card-header bg-dark text-light">
        Table
      </div>
        <div class="card-body">
          {% include "./_table.njk" %}
        </div>
      </div>
    </div>
  </div>

  {% if managerStats %}
  <div class="row" style="padding-bottom: 20px;">
    <div class="col-lg-12">
      <div class="card border-dark">
        <div class="card-header bg-dark text-light">
          Season Statistics
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-lg-6">
              <h6>Current Form</h6>
              <div style="padding-bottom: 15px;">
                {% for result in managerStats.form %}
                  {% if result === 'W' %}
                    <span class="badge badge-success">W</span>
                  {% elif result === 'D' %}
                    <span class="badge badge-warning">D</span>
                  {% elif result === 'L' %}
                    <span class="badge badge-danger">L</span>
                  {% else %}
                    <span class="badge badge-secondary">{{ result }}</span>
                  {% endif %}
                {% endfor %}
              </div>

              <h6>Current Streak</h6>
              <p>
                {% if managerStats.currentStreak.type === 'none' %}
                  No current streak
                {% else %}
                  {{ managerStats.currentStreak.count }}
                  {% if managerStats.currentStreak.type === 'W' %}win{% elif managerStats.currentStreak.type === 'D' %}draw{% else %}loss{% endif %}{% if managerStats.currentStreak.count > 1 %}{% if managerStats.currentStreak.type === 'L' %}es{% else %}s{% endif %}{% endif %}
                {% endif %}
              </p>
            </div>

            <div class="col-lg-6">
              <h6>Season Stats</h6>
              <table class="table table-sm">
                <tbody>
                  <tr>
                    <td class="font-weight-bold">Total Goals</td>
                    <td>{{ managerStats.totalGoals }}</td>
                  </tr>
                  <tr>
                    <td class="font-weight-bold">Total Conceded</td>
                    <td>{{ managerStats.totalConceded }}</td>
                  </tr>
                  {% if managerStats.bestWeek %}
                  <tr>
                    <td class="font-weight-bold">Best Week</td>
                    <td>GW{{ managerStats.bestWeek.gameweekId }} ({{ managerStats.bestWeek.goals }}-{{ managerStats.bestWeek.conceded }})</td>
                  </tr>
                  {% endif %}
                  {% if managerStats.worstWeek %}
                  <tr>
                    <td class="font-weight-bold">Worst Week</td>
                    <td>GW{{ managerStats.worstWeek.gameweekId }} ({{ managerStats.worstWeek.goals }}-{{ managerStats.worstWeek.conceded }})</td>
                  </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}
{% endblock %}

{% block bodyEnd %}
  <script>
    const manager = {{ manager | dump | safe }} // eslint-disable-line
  </script>
  <script src="{{ asset('javascripts/manager.js') }}"></script>
{% endblock %}
