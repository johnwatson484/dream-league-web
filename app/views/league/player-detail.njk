{% extends '_layout.njk' %}

{% block content %}
  <h2>{{ player.firstName }} {{ player.lastName }}</h2>

  <div class="card border-dark">
    <div class="card-header bg-dark text-light">
      Player Information
    </div>
    <div class="card-body small">
      <dl class="row">
        <dt class="col-sm-3">Position</dt>
        <dd class="col-sm-9">{{ player.position }}</dd>

        <dt class="col-sm-3">Team</dt>
        <dd class="col-sm-9">
          <a href="/league/team/detail?teamId={{ player.team.teamId }}">{{ player.team.name }}</a>
          {% if player.team.division %}
            ({{ player.team.division.name }})
          {% endif %}
        </dd>

        <dt class="col-sm-3">Goals Scored</dt>
        <dd class="col-sm-9">
          {{ leagueGoals }} (League)
          {% if cupGoals > 0 %}
            + {{ cupGoals }} (Cup)
          {% endif %}
        </dd>

        {% if player.managers and player.managers.length > 0 %}
        <dt class="col-sm-3">Manager</dt>
        <dd class="col-sm-9">
          {% for manager in player.managers %}
            <a href="/manager?managerId={{ manager.managerId }}">{{ manager.name }}</a>
            {% if manager.managerPlayer.substitute %}(substitute){% endif %}
            {% if not loop.last %}, {% endif %}
          {% endfor %}
        </dd>
        {% endif %}
      </dl>
    </div>
  </div>

  <div class="mt-3">
    <a href="/league/players">← Back to Players</a>
    {% if auth.isAdmin %}
      | <a href="/league/player/edit?playerId={{ player.playerId }}">Edit</a>
      | <a href="/league/player/delete?playerId={{ player.playerId }}">Delete</a>
    {% endif %}
  </div>
{% endblock %}
