{% extends '_layout.njk' %}

{% block content %}
  <h2>Players</h2>

  <div class="row">
    <div class="col-md-6">
      <form method="GET" action="/league/players">
        <div class="input-group mb-3">
          <input type="text" class="form-control" name="search" id="search" value="{{ currentSearch }}">
          <input type="hidden" name="position" value="{{ currentPosition }}">
          <div class="input-group-append">
            <button class="btn btn-outline-secondary" type="submit" id="button-addon2">Search</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-12">
      <div class="btn-group" role="group" aria-label="Position filter">
        <a href="/league/players?search={{ currentSearch }}" class="btn btn-sm {% if not currentPosition %}btn-primary{% else %}btn-outline-primary{% endif %}">All</a>
        <a href="/league/players?search={{ currentSearch }}&position=Defender" class="btn btn-sm {% if currentPosition == 'Defender' %}btn-primary{% else %}btn-outline-primary{% endif %}">Defenders</a>
        <a href="/league/players?search={{ currentSearch }}&position=Midfielder" class="btn btn-sm {% if currentPosition == 'Midfielder' %}btn-primary{% else %}btn-outline-primary{% endif %}">Midfielders</a>
        <a href="/league/players?search={{ currentSearch }}&position=Forward" class="btn btn-sm {% if currentPosition == 'Forward' %}btn-primary{% else %}btn-outline-primary{% endif %}">Forwards</a>
      </div>
    </div>
  </div>

  {% if auth.isAdmin %}
  <a href="/league/player/create">Create player</a>
  {% endif %}

  {%if players.length %}
    <table class="table table-hover table-sm small">
      <tr>
        <th>Name</th>
        <th>Position</th>
        <th>Team</th>
        <th>Manager</th>
        <th></th>
      </tr>
      {% for player in players %}
        <tr>
          <td><a href="/league/player/detail?playerId={{ player.playerId }}">{{ player.lastNameFirstName }}</a></td>
          <td>{{ player.position }}</td>
          <td><a href="/league/team/detail?teamId={{ player.team.teamId }}">{{ player.team.name }}</a></td>
          <td>
            {% if player.managers.length %}
              <a href="/manager?managerId={{ player.managers[0].managerId }}">{{ player.managers[0].name }}</a>
            {% endif %}
          </td>
          <td>
            {% if auth.isAdmin %}
            <a href="/league/player/edit?playerId={{ player.playerId }}">Edit</a> | <a href="/league/player/delete?playerId={{ player.playerId }}">Delete</a>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
    </table>
  {% else %}
    <div class="alert alert-info">
      No players available.
    </div>
  {% endif %}
{% endblock %}
