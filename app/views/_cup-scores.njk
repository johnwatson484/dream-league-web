{% set sortedScores = results.cupScores | sort(attribute='cupName') %}
{% set lastCupName = null %}
<table class="table table-hover table-sm small">
  {% for score in sortedScores %}
    {% if lastCupName != score.cupName %}
      {% if not loop.first %}</table>{% endif %}
      <h6>{{ score.cupName }}</h6>
      <table class="table table-hover table-sm small">
      {% set lastCupName = score.cupName %}
    {% endif %}
    <tr>
      <td class="numeric">R{{ score.round }}</td>
      <td><a href="/manager?managerId={{ score.homeScore.managerId }}">{{ score.homeScore.manager }}</a></td>
      <td>{{ score.homeMargin }}</td>
      <td> v </td>
      <td>{{ score.awayMargin }}</td>
      <td><a href="/manager?managerId={{ score.awayScore.managerId }}">{{ score.awayScore.manager }}</a></td>
    </tr>
    {% if loop.last %}</table>{% endif %}
  {% endfor %}
