{
  "name": "dream-league-web",
  "version": "2.0.1",
  "description": "Dream League web frontend",
  "type": "module",
  "main": "app/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node app/index.js",
    "dev": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./app app/index.js",
    "dev:debug": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./app --inspect app/index.js",
    "local": "npm run dev",
    "docker:build": "docker compose --profile app build",
    "docker:dev": "docker compose --profile app up",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:unit": "cross-env TZ=UTC vitest run --coverage --project unit",
    "test:integration": "cross-env TZ=UTC vitest run --coverage --project integration",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:debug": "cross-env TZ=UTC vitest --inspect --no-file-parallelism",
    "test:lint": "eslint"
  },
  "author": "John Watson",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "10.0.0",
    "@hapi/crumb": "8.0.1",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.2",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.0",
    "@hapi/wreck": "18.1.2",
    "blankie": "5.0.0",
    "hapi-auth-jwt2": "10.7.0",
    "hapi-pino": "10.1.0",
    "joi": "17.13.4",
    "nunjucks": "3.2.4",
    "qs": "6.15.2",
    "semver": "7.7.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "blipp": "4.0.2",
    "cross-env": "10.1.0",
    "eslint": "9.7.0",
    "neostandard": "0.11.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "tmp": "0.2.5"
  }
}
